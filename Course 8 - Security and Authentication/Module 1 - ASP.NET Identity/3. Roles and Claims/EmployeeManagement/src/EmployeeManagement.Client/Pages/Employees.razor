@page "/employees"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject EmployeeService EmployeeService

<div class="page-header">
    <div class="d-flex align-center gap-3">
        <MudText Typo="Typo.h4">Employee Directory</MudText>
        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">
            @_employees.Count
        </MudChip>
    </div>
    <MudText Typo="Typo.body2" Class="page-subtitle">Browse and search company employees</MudText>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudPaper Elevation="0" Class="flat-card">
        <MudDataGrid T="EmployeeResponse" Items="_employees" Filterable="true" FilterMode="DataGridFilterMode.Simple"
                     Hover="true" Dense="true" Class="pa-2">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Employees</MudText>
                <MudSpacer />
            </ToolBarContent>
            <Columns>
                <TemplateColumn Title="Employee" Sortable="false">
                    <CellTemplate>
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                @($"{context.Item.FirstName[0]}{context.Item.LastName[0]}")
                            </MudAvatar>
                            <div>
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Item.FirstName @context.Item.LastName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Item.Email</MudText>
                            </div>
                        </div>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Department" Title="Department">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Color="GetDeptColor(context.Item.Department)">
                            @context.Item.Department
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>
                <PropertyColumn Property="x => x.Position" Title="Position" />
            </Columns>
            <PagerContent>
                <MudDataGridPager T="EmployeeResponse" />
            </PagerContent>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<EmployeeResponse> _employees = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _employees = await EmployeeService.GetEmployeesAsync();
        }
        catch { }
        _loading = false;
    }

    private Color GetDeptColor(string dept) => dept switch
    {
        "IT" => Color.Primary,
        "HR" => Color.Secondary,
        "Finance" => Color.Tertiary,
        _ => Color.Default
    };
}
