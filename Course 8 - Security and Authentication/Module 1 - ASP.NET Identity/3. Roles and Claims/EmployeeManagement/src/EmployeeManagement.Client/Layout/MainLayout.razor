@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="AppTheme.Default" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <AuthorizeView>
        <Authorized>
            <MudAppBar Elevation="0"
                       Style="@(_isDarkMode
                           ? "background: linear-gradient(135deg, #1E1B4B, #312E81); border-bottom: 1px solid rgba(255,255,255,0.06);"
                           : "background: linear-gradient(135deg, #4F46E5, #7C3AED);")">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="ToggleDrawer" />
                <MudText Typo="Typo.h6" Class="ml-2" Style="font-weight: 600; letter-spacing: -0.02em;">
                    HR Employee Management
                </MudText>
                <MudSpacer />
                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit" OnClick="ToggleDarkMode" />
                <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight">
                    <MudMenuItem Href="/profile" Icon="@Icons.Material.Filled.Person">Profile</MudMenuItem>
                    <MudMenuItem OnClick="LogoutAsync" Icon="@Icons.Material.Filled.Logout">Logout</MudMenuItem>
                </MudMenu>
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
                       Style="border-right: 1px solid var(--mud-palette-divider);">
                <NavMenu />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    <MudMainContent Style="padding: 88px 24px 24px 24px;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode;
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
